SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_ANON_KEY
PORT=3000

# Billplz configuration
BILLPLZ_API_KEY=YOUR_BILLPLZ_API_KEY
BILLPLZ_COLLECTION_ID=YOUR_BILLPLZ_COLLECTION_ID
BILLPLZ_SANDBOX=true
BILLPLZ_X_SIGNATURE_KEY=YOUR_BILLPLZ_X_SIGNATURE_KEY

APP_BASE_URL=https://your-app.vercel.app

# Telegram notifications
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Admin authentication (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD

# CSRF protection (must be a random string, at least 32 chars)
CSRF_SECRET=YOUR_RANDOM_CSRF_SECRET_DO_NOT_REUSE
